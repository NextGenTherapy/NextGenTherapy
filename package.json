{
  "name": "next-gen-therapy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "postbuild": "next-sitemap",
    "format": "prettier --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:coverage && npm run test:e2e",
    "perf:check": "node scripts/performance-check.js",
    "perf:lighthouse": "npm run perf:check",
    "perf:budget": "npm run perf:check && echo 'Performance budget check completed'",
    "test:visual": "playwright test visual-regression.spec.ts",
    "test:perf": "npm run perf:check",
    "monitor:health": "node monitoring/health-monitor.js",
    "monitor:test": "node -e \"console.log('Testing monitoring system...'); require('./monitoring/health-monitor.js').runHealthChecks().then(success => { console.log('Monitor test:', success ? 'PASSED' : 'FAILED'); process.exit(success ? 0 : 1); })\"",
    "backup:create": "node scripts/backup-strategy.js backup",
    "backup:verify": "node scripts/backup-strategy.js verify",
    "backup:report": "node scripts/backup-strategy.js report",
    "backup:cleanup": "node scripts/backup-strategy.js cleanup",
    "a11y:audit": "axe http://localhost:3000 http://localhost:3000/about http://localhost:3000/therapy-for-women http://localhost:3000/romanian-therapy http://localhost:3000/book-now http://localhost:3000/faq --tags wcag2a,wcag2aa --exit",
    "og:generate": "npx ts-node scripts/generate-og-images.ts"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "gray-matter": "^4.0.3",
    "html-to-text": "^9.0.5",
    "next": "^16.2.3",
    "next-sitemap": "^4.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "resend": "^6.10.0",
    "sass": "^1.89.2",
    "validator": "^13.15.15",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.1",
    "@eslint/eslintrc": "^3",
    "@lhci/cli": "^0.15.1",
    "@next/eslint-plugin-next": "^16.2.3",
    "@playwright/test": "^1.55.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/validator": "^13.15.3",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "chrome-launcher": "^1.2.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lighthouse": "^13.1.0",
    "prettier": "^3.6.0",
    "typescript": "^6.0.2"
  }
}
